<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 定义一个沉睡的计划任务 -->
        <record id="ir_cron_auto_build_pdf_index" model="ir.cron">
            <field name="name">自动处理 PDF 图纸索引队列</field>
            <field name="model_id" ref="model_material_tracker_drawing"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_index_queue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <!-- 删除了 numbercall 这一行 -->
            <field name="active" eval="False"/> <!-- 默认不启用，等前端唤醒 -->
        </record>
    </data>
</odoo>