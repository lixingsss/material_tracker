<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 沉浸式预览视图：增加手动关闭按钮，去掉所有容器 -->
    <record id="view_material_tracker_drawing_immersive" model="ir.ui.view">
        <field name="name">material_tracker.drawing.immersive</field>
        <field name="model">material_tracker.drawing</field>
        <field name="arch" type="xml">
            <form string="图纸预览" create="0" edit="0" delete="0" class="o_pdf_preview_full_modal">
                <!-- 自定义浮动关闭按钮，点击即关闭弹窗 -->
                <button string="×" special="cancel" class="o_btn_close_floating"/>
                
                <!-- PDF 控件 -->
                <field name="cache_result_file" widget="pdf_viewer" nolabel="1"/>
            </form>
        </field>
    </record>

    <!-- 图纸管理列表视图 -->
    <record id="view_material_tracker_drawing_tree" model="ir.ui.view">
        <field name="name">material_tracker.drawing.tree</field>
        <field name="model">material_tracker.drawing</field>
        <field name="arch" type="xml">
            <list string="图纸管理">
                <field name="name"/>
                <field name="index_status" widget="badge" 
                       decoration-info="index_status == '未建立'" 
                       decoration-warning="index_status in ('排队中', '处理中')"
                       decoration-danger="index_status == '失败'"
                       decoration-success="index_status == '已建立'"/>
            </list>
        </field>
    </record>

    <!-- 图纸管理完整表单视图 -->
    <record id="view_material_tracker_drawing_form" model="ir.ui.view">
        <field name="name">material_tracker.drawing.form</field>
        <field name="model">material_tracker.drawing</field>
        <field name="arch" type="xml">
            <form string="图纸管理">
                <header>
                    <button name="action_queue_build_index" string="建立索引" type="object" 
                            class="btn-primary" invisible="index_status in ('已建立', '排队中', '处理中')"/>
                    <button name="action_clear_index" string="清除索引" type="object" 
                            invisible="index_status in ('未建立', '排队中', '处理中')"/>
                    <field name="index_status" widget="statusbar" statusbar_visible="未建立,排队中,处理中,已建立"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="pdf_file" filename="name"/>
                    </group>
                    <group>
                        <label for="search_keyword" string="检索图号"/>
                        <div class="o_row">
                            <field name="search_keyword"/>
                            <button name="action_search_and_slice" string="搜索并提取" 
                                    type="object" class="btn-primary" icon="fa-search"/>
                        </div>
                    </group>
                    <notebook>
                        <page string="预览">
                            <field name="cache_result_file" widget="pdf_viewer" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_material_tracker_drawing" model="ir.actions.act_window">
        <field name="name">图纸管理</field>
        <field name="res_model">material_tracker.drawing</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>