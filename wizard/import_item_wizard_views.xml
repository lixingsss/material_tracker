<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_tracker_import_wizard_form" model="ir.ui.view">
        <field name="name">material.tracker.import.wizard.form</field>
        <field name="model">material.tracker.import.wizard</field>
        <field name="arch" type="xml">
            <form string="导入料号">
                <group>
                    <field name="attachment_ids" widget="many2many_binary" string="上传 Excel (可多选)"/>
                    <field name="exist_action" widget="radio" options="{'horizontal': true}"/>
                </group>
                <footer>
                    <button string="确认导入" name="action_import" type="object" class="btn-primary"/>
                    <button string="取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_item_wizard" model="ir.actions.act_window">
        <field name="name">批量导入</field>
        <field name="res_model">material.tracker.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
